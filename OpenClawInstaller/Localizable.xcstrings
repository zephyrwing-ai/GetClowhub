          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda bawa idea, saya bina repo dan hantar ke bintang"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jij brengt de ideeën, ik bouw repos en lever ze af"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
