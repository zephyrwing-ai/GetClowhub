    "The task timed out and has been terminated. You can try again or switch to another agent." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتهت مهلة المهمة وتم إنهاؤها. يمكنك المحاولة مرة أخرى أو التبديل إلى وكيل آخر."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opgaven fik timeout og blev afsluttet. Du kan prøve igen eller skifte til en anden agent."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Aufgabe wurde wegen Zeitüberschreitung beendet. Sie können es erneut versuchen oder zu einem anderen Agenten wechseln."
          }
        },
        "el" : {
          "stringUnit" : {
