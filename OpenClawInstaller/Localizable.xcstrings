    "This will remove OpenClaw, Node.js runtime and log files.\nConfiguration and login data will be preserved." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى حذف برنامج OpenClaw وبيئة Node.js وملفات السجل.\nسيتم الاحتفاظ بملفات الإعداد وبيانات تسجيل الدخول."
          }
        },
        "da" : {
          "stringUnit" : {
