    "You bring ideas, I build repos and ship to stars" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت تأتي بالأفكار، وأنا أبني المستودعات وأوصلها للنجوم"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bringer ideerne, jeg bygger repos og sender dem til stjernerne"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie liefern die Ideen, ich baue Repos und bringe sie zu den Sternen"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εσείς φέρνετε τις ιδέες, εγώ δημιουργώ αποθετήρια και τα φτάνω στα αστέρια"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tú traes las ideas, yo construyo repos y los llevo a las estrellas"
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شما ایده می‌دهید، من مخازن را می‌سازم و به ستاره‌ها می‌رسانم"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sinä tuot ideat, minä rakennan repot ja julkaisen ne"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous apportez les idées, je construis les dépôts et les propulse"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ön hozza az ötleteket, én építem a repókat és juttatom el a csillagokig"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda bawa ide, saya bangun repo dan kirim ke bintang"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu porti le idee, io creo repository e li porto al successo"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイデアを出すだけで、リポジトリ作成からスターまでお任せ"
