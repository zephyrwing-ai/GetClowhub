    "Configuration and login data preserved. Can be restored after reinstallation." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم الاحتفاظ بملفات الإعداد وبيانات تسجيل الدخول. يمكن استعادتها بعد إعادة التثبيت."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konfiguration og logindata bevaret. Kan gendannes efter geninstallation."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konfiguration und Anmeldedaten wurden beibehalten. Können nach Neuinstallation wiederhergestellt werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Τα αρχεία ρυθμίσεων και σύνδεσης διατηρήθηκαν. Μπορούν να αποκατασταθούν μετά την επανεγκατάσταση."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configuración y datos de inicio de sesión conservados. Se pueden restaurar después de la reinstalación."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تنظیمات و اطلاعات ورود حفظ شده‌اند. پس از نصب مجدد قابل بازیابی هستند."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asetukset ja kirjautumistiedot säilytetty. Voidaan palauttaa uudelleenasennuksen jälkeen."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Napanatili ang configuration at login data. Maaaring i-restore pagkatapos ng muling pag-install."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configuration et données de connexion conservées. Peuvent être restaurées après réinstallation."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A beállítások és bejelentkezési adatok megőrizve. Újratelepítés után visszaállíthatók."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konfigurasi dan data login dipertahankan. Dapat dipulihkan setelah instalasi ulang."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configurazione e dati di accesso conservati. Possono essere ripristinati dopo la reinstallazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定ファイルとログイン情報は保持されます。再インストール後に復元できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "설정 파일과 로그인 정보가 보존됩니다. 재설치 후 복원할 수 있습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konfigurasi dan data log masuk dikekalkan. Boleh dipulihkan selepas pemasangan semula."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configuratie en inloggegevens bewaard. Kunnen worden hersteld na herinstallatie."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
