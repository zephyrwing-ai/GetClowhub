    "Go to DingTalk Open Platform to create an app and get the App Key and App Secret." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتقل إلى منصة DingTalk المفتوحة لإنشاء تطبيق والحصول على مفتاح التطبيق وسره."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gå til DingTalk Open Platform for at oprette en app og få App Key og App Secret."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gehen Sie zur DingTalk Open Platform, um eine App zu erstellen und den App-Schlüssel und das App-Geheimnis zu erhalten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μεταβείτε στην πλατφόρμα DingTalk Open Platform για να δημιουργήσετε μια εφαρμογή και να λάβετε το κλειδί και το μυστικό."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaya a la plataforma abierta de DingTalk para crear una aplicación y obtener la clave y el secreto."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "به پلتفرم باز DingTalk بروید و یک برنامه بسازید و کلید و رمز را دریافت کنید."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siirry DingTalk Open Platformiin luodaksesi sovelluksen ja saadaksesi App Key ja App Secret."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pumunta sa DingTalk Open Platform para gumawa ng app at kunin ang App Key at App Secret."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rendez-vous sur la plateforme ouverte DingTalk pour créer une application et obtenir la clé et le secret."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lépjen a DingTalk Open Platformra egy alkalmazás létrehozásához és a kulcs és titok megszerzéséhez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka DingTalk Open Platform untuk membuat aplikasi dan mendapatkan App Key dan App Secret."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vai su DingTalk Open Platform per creare un'app e ottenere la chiave e il segreto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DingTalk オープンプラットフォームでアプリを作成し、App Key と App Secret を取得してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "DingTalk 오픈 플랫폼에서 앱을 만들고 App Key와 App Secret을 받으세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pergi ke DingTalk Open Platform untuk membuat aplikasi dan mendapatkan App Key dan App Secret."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ga naar het DingTalk Open Platform om een app te maken en de App Key en App Secret te verkrijgen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przejdź do DingTalk Open Platform, aby utworzyć aplikację i uzyskać App Key i App Secret."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acesse a plataforma aberta do DingTalk para criar um aplicativo e obter a chave e o segredo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
