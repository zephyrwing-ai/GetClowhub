          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configuração e dados de login preservados. Podem ser restaurados após a reinstalação."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Конфигурация и данные входа сохранены. Могут быть восстановлены после переустановки."
          }
        },
        "sv" : {
          "stringUnit" : {
