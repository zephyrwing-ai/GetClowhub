    "Error details have been copied to your clipboard. Please paste them when reporting the issue." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم نسخ تفاصيل الخطأ إلى الحافظة. يُرجى لصقها عند الإبلاغ عن المشكلة."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fejloplysninger er kopieret til din udklipsholder. Indsæt dem venligst, når du rapporterer problemet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fehlerdetails wurden in Ihre Zwischenablage kopiert. Bitte fügen Sie diese beim Melden des Problems ein."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι λεπτομέρειες σφάλματος αντιγράφηκαν στο πρόχειρό σας. Επικολλήστε τις κατά την αναφορά του προβλήματος."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los detalles del error se han copiado al portapapeles. Pégalos al reportar el problema."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جزئیات خطا به کلیپ‌بورد شما کپی شد. لطفاً هنگام گزارش مشکل آن‌ها را جای‌گذاری کنید."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Virhetiedot on kopioitu leikepöydällesi. Liitä ne ilmoittaessasi ongelmasta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les détails de l'erreur ont été copiés dans votre presse-papiers. Veuillez les coller lors du signalement du problème."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A hiba részletei a vágólapra másolva. Kérjük, illessze be a probléma bejelentésekor."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detail kesalahan telah disalin ke papan klip Anda. Silakan tempel saat melaporkan masalah."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I dettagli dell'errore sono stati copiati negli appunti. Incollali quando segnali il problema."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "エラーの詳細がクリップボードにコピーされました。問題を報告する際に貼り付けてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오류 세부 정보가 클립보드에 복사되었습니다. 문제를 신고할 때 붙여넣으세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Butiran ralat telah disalin ke papan keratan anda. Sila tampalkan semasa melaporkan isu."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foutdetails zijn gekopieerd naar uw klembord. Plak ze bij het melden van het probleem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os detalhes do erro foram copiados para a área de transferência. Cole-os ao reportar o problema."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Данные об ошибке скопированы в буфер обмена. Вставьте их при отправке отчёта о проблеме."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Felinformationen har kopierats till urklipp. Klistra in den när du rapporterar problemet."
