        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "รายละเอียดข้อผิดพลาดถูกคัดลอกไปยังคลิปบอร์ดของคุณแล้ว กรุณาวางเมื่อรายงานปัญหา"
          }
        },
        "tr" : {
